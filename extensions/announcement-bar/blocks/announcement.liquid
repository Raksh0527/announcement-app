{% assign announcement = shop.metafields.announcement.message.value %}

<div class="announcement-bar">
  {% if announcement != blank %}
    {{ announcement }}
  {% else %}
    No announcement available
  {% endif %}
</div>

<style>
.announcement-bar{
  width:100%;
  background:#000;
  color:#fff;
  text-align:center;
  padding:15px;
  font-size:18px;
  font-weight:600;
}
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "target": "section",
  "settings": []
}
{% endschema %}